{
  "workbench.settings.editor": "ui",
  // Editor settings
  // "breadcrumbs.enabled": false,

  "editor.autoIndent": "full",
  "editor.codeLensFontFamily": "JetBrainsMono NF",
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.cursorSurroundingLines": 4,
  "editor.cursorWidth": 3,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "Maple Mono NF, JetBrainsMono Nerd Font, Menlo, Monaco, 'Courier New', monospacere",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "600",
  "editor.inlayHints.fontFamily": "JetBrainsMono Nerd Font",
  "editor.inlayHints.fontSize": 10,
  "editor.inlayHints.padding": true,
  "editor.inlineSuggest.enabled": true,
  "editor.insertSpaces": false,
  "editor.letterSpacing": 0.5,
  // "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",

  // Error lens
  "errorLens.enabledDiagnosticLevels": ["warning", "error"],
  "errorLens.excludeBySource": ["cSpell"],

  // Extensions / Performance

  // Files
  "files.associations": {
    "*.css": "tailwindcss",
  },
  "files.trimTrailingWhitespace": true,

  // Git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",

  // AI features
  "chat.agent.maxRequests": 50,
  "chat.tools.edits.autoApprove": {
    "**/*": true,
    "**/.vscode/*.json": false,
    "**/.git/**": false,
    "**/{package.json,package-lock.json,server.xml,build.rs,web.config,.gitattributes,.env}": false,
    "**/*.{csproj,fsproj,vbproj}": false,
  },
  "chat.tools.terminal.enableAutoApprove": true,
  "inlineChat.enableV2": true,
  "chat.mcp.autostart": "newAndOutdated",
  "chat.agent.enabled": true,
  "chat.agent.thinkingStyle": "collapsedPreview",
  "chat.extensionTools.enabled": true,
  "chat.mcp.access": "all",
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.newWorkspace.useContext7": true,
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.reviewAgent.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Analyze staged changes and generate a conventional commit message: type(scope): description\n\nTypes: feat, fix, etc.\nFocus on WHAT and WHY.",
    },
    {
      "text": "Use an icon at the beginning of the commit message to increase recognition and make the commit history easier to read. For example: 🚀 feat(auth): Add Google login feature.",
    },
  ],
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "properties": false,
    "shellscript": false,
    "dotenv": false,
  },
  "github.copilot.nextEditSuggestions.enabled": true,

  // JavaScript language settings
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "literals",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.validate.enable": false,

  // Material / UI
  "material-icon-theme.activeIconPack": "react_redux",

  // Terminal & Debug
  "terminal.integrated.env.linux": {},
  "terminal.integrated.fontFamily": "Maple Mono NF",
  "terminal.integrated.fontLigatures.enabled": true,
  "debug.console.fontFamily": "JetBrainsMono NF",
  // "terminal.integrated.suggest.enabled": true,

  // TypeScript language settings
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",

  // UI / Workbench
  "explorer.confirmDragAndDrop": false,
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#ffc600",
    "tab.activeBorder": "#ffc600",
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.statusBar.visible": true,

  // Window
  "window.newWindowProfile": "Default",
  "editor.aiStats.enabled": true,
  "settingsSync.ignoredSettings": ["vscode-neovim.useWSL"],
  "settingsSync.ignoredExtensions": ["ms-vscode-remote.remote-wsl"],
  "cSpell.language": "en",
  "chat.tools.terminal.autoApprove": {
    "pnpm": true,
    "mkdir": true,
    "mv": true,
    "touch": true,
    "git branch": true,
    "git commit": true,
    "git ls-files": true,
    "true": true,
    "jobs": true,
    "tee": true,
  },
  "chat.mcp.serverSampling": {
    "Global in Code: context7": {
      "allowedModels": ["copilot/gpt-4.1"],
    },
  },
  "security.workspace.trust.untrustedFiles": "open",
  "chat.mcp.gallery.enabled": true,

  // Language specific settings
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
    "editor.formatOnSave": true,
  },
  "[xml]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
  },
  "remote.autoForwardPortsSource": "hybrid",
  "claudeCode.environmentVariables": [
    {
      "name": "ANTHROPIC_BASE_URL",
      "value": " http://localhost:20128/v1",
    },
    {
      "name": "ANTHROPIC_API_KEY",
      "value": "sk-b9ff74bada541c81-fkh2x8-c4879c51",
    },
    {
      "name": "ANTHROPIC_DEFAULT_OPUS_MODEL",
      "value": "opencode-premium",
    },
    {
      "name": "ANTHROPIC_DEFAULT_SONNET_MODEL",
      "value": "cx/gpt-5.3-codex",
    },
    {
      "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "value": "cx/gpt-5.4-mini",
    },
  ],
  "claudeCode.preferredLocation": "panel",
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
  ],
  "kilo-code.new.autocomplete.enableAutoTrigger": false,
  "kilo-code.new.autocomplete.enableSmartInlineTaskKeybinding": false,
  "kilo-code.new.autocomplete.enableChatAutocomplete": true,
  "explorer.confirmDelete": false,
  "tailwindCSS.emmetCompletions": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "chatgpt.runCodexInWindowsSubsystemForLinux": true,
  "chatgpt.composerEnterBehavior": "cmdIfMultiline",
  "workbench.browser.enableChatTools": true,
  "chat.agent.sandbox.enabled": "on",
  "terminal.external.linuxExec": "zsh",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "chatgpt.localeOverride": "vi-VN",
  "kilo-code.new.browserAutomation.enabled": true,
  "kilo-code.new.browserAutomation.headless": true,
  "kilo-code.new.claudeCodeCompat": true,
  "chat.plugins.marketplaces": [
    "github/copilot-plugins",
    "github/awesome-copilot",
    "EveryInc/compound-engineering-plugin",
  ],
  "workbench.secondarySideBar.showLabels": false,
  "claudeCode.useTerminal": true,
  "chat.viewSessions.orientation": "stacked",
  "workbench.activityBar.compact": true,
}