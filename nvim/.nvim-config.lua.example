-- Project-specific Neovim configuration for Monorepo/Micro-frontend projects
-- Copy this file to .nvim-config.lua in your project root directory

-- =============================================================================
-- TypeScript LSP Configuration
-- =============================================================================
-- Choose your TypeScript language server:
-- - "vtsls": Better performance, better monorepo support (recommended)
-- - "ts_ls": Standard TypeScript language server
vim.g.lsp_typescript_server = "vtsls"

-- =============================================================================
-- Enable Additional LSP Servers
-- =============================================================================
-- Enable on-demand LSP servers for your project
vim.g.lsp_on_demands = {
  "eslint",       -- ESLint for linting
  "tailwindcss",  -- Tailwind CSS IntelliSense
  -- Add more as needed: "biome", "json", etc.
}

-- =============================================================================
-- Enable Extra Plugins
-- =============================================================================
-- Enable additional plugins for your project
vim.g.enable_extra_plugins = {
  -- Add plugin names here
}

-- =============================================================================
-- Project-Specific Settings
-- =============================================================================

-- For pnpm monorepo projects:
-- The LSP will automatically detect pnpm-workspace.yaml and resolve dependencies

-- For Turborepo projects:
-- The LSP will automatically detect turbo.json and configure workspace roots

-- For Nx monorepo projects:
-- The LSP will automatically detect nx.json and configure workspace roots

-- For Lerna projects:
-- The LSP will automatically detect lerna.json and configure workspace roots

-- =============================================================================
-- Custom Settings (Optional)
-- =============================================================================

-- Override tab/space settings for specific project
-- vim.opt.tabstop = 2
-- vim.opt.shiftwidth = 2
-- vim.opt.expandtab = true

-- Enable/disable specific features
-- vim.g.disable_autoformat = true  -- Disable auto-format on save

-- =============================================================================
-- Tips for Monorepo Projects
-- =============================================================================
-- 1. Make sure your monorepo root has a proper tsconfig.json or jsconfig.json
-- 2. For pnpm workspaces, ensure pnpm-workspace.yaml is at the root
-- 3. For Tailwind CSS, ensure tailwind.config.js is in the correct package
-- 4. For ESLint, ensure .eslintrc or eslint.config.js is properly configured
--
-- The LSP servers will automatically detect the workspace structure and
-- configure themselves based on the root markers (tsconfig.json, package.json,
-- pnpm-workspace.yaml, turbo.json, etc.)
-- =============================================================================
