{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"9router": {
			"npm": "@ai-sdk/openai-compatible",
			"options": {
				"baseURL": "http://127.0.0.1:20128/v1"
			},
			"models": {
				"opencode-premium": {
					"name": "opencode-premium",
					"modalities": {
						"input": ["image", "text"],
						"output": ["text"]
					}
				},
				"opencode-fast": {
					"name": "opencode-fast",
					"modalities": {
						"input": ["image", "text"],
						"output": ["text"]
					}
				}
			}
		}
	},
	"model": "9router/opencode-premium",
	"plugin": ["opencode-agent-skills", "oh-my-opencode-slim"],
	"skills": {
		"paths": ["$HOME/.config/opencode/skills/mattpocock"]
	},
	"mcp": {
		"agentmemory": {
			"type": "local",
			"command": ["npx", "-y", "@agentmemory/mcp"],
			"enabled": true,
			"env": {
				"AGENTMEMORY_URL": "http://localhost:3111"
			}
		}
	},
	"agent": {
		"explorer": {
			"description": "Fast explorer subagent for codebase exploration",
			"mode": "subagent",
			"model": "opencode/deepseek-v4-flash-free"
		},
		"explore": {
			"description": "Fast explorer subagent for codebase exploration",
			"mode": "subagent",
			"model": "opencode/deepseek-v4-flash-free",
			"disable": true
		},
		"build": {
			"disable": true
		},
		"general": {
			"disable": true
		},
		"plan": {
			"disable": true
		}
	},
	"lsp": true
}
